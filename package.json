{
    "name": "node-red-contrib-tak-registration",
    "version": "1.0.1",
    "description": "A Node-RED node to register to TAK and to help wrap files as datapackages to send to TAK",
    "dependencies": {
        "@turf/helpers": "7.3.5",
        "@turf/centroid": "7.3.5",
        "adm-zip": "0.6.0",
        "axios": "1.18.1",
        "fast-xml-parser": "5.9.3",
        "form-data": "4.0.6",
        "long": "5.3.2",
        "protobufjs": "8.7.0",
        "uuid": "14.0.1"
    },
    "bundledDependencies": [
        "@turf/helpers",
        "@turf/centroid",
        "adm-zip",
        "axios",
        "fast-xml-parser",
        "form-data",
        "long",
        "protobufjs",
        "uuid"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/dceejay/takreg/tree/master/"
    },
    "license": "Apache-2.0",
    "keywords": [
