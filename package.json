        "version": ">=4.0.0",
        "nodes": {
            "tak registration": "tak-registration.js",
            "tak ingest": "tak-ingest.js"
        }
    },
    "author": {
        "name": "Dave Conway-Jones",
        "email": "dceejay@gmail.com"
    },
    "engines": {
